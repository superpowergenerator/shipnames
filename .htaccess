# ---------------------------------------------------------------------
# Ship Names - Apache / cPanel configuration
# Safe to leave in place on hosts that ignore it (e.g. GitHub Pages).
# ---------------------------------------------------------------------

# Custom 404 page
ErrorDocument 404 /404.html

<IfModule mod_rewrite.c>
  RewriteEngine On

  # Force the canonical homepage: /index.html -> /  (301, avoids duplicate content)
  RewriteCond %{THE_REQUEST} \s/+index\.html[\s?] [NC]
  RewriteRule ^index\.html$ / [R=301,L]

  # Strip trailing slashes from non-directory URLs (e.g. /blog.html/ -> /blog.html)
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule ^(.+)/$ /$1 [R=301,L]
</IfModule>

# ---------------------------------------------------------------------
# Caching + compression (performance)
# ---------------------------------------------------------------------
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css application/javascript image/svg+xml application/xml
</IfModule>

<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/css "access plus 1 month"
  ExpiresByType application/javascript "access plus 1 month"
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
  ExpiresByType text/html "access plus 1 day"
</IfModule>
